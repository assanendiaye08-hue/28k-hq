// Discord Hustler - Prisma Schema
// Phase 1: member identity, profiles, private spaces, account linking, interest tags.
// Phase 2: check-ins, goals, XP transactions, member schedules.

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
  // Connection URL is configured in prisma.config.ts (Prisma 7 requirement)
}

/// Core identity -- one per real person.
/// All linked Discord accounts point to the same Member.
model Member {
  id              String    @id @default(cuid())
  displayName     String
  encryptionSalt  String    // Random 16-byte hex for per-member key derivation
  recoveryKeyHash String    // Hash of recovery key (to verify, not to decrypt)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Phase 2: XP and streak tracking
  totalXp       Int       @default(0)
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastCheckInAt DateTime?

  // Relations
  accounts              DiscordAccount[]
  profile               MemberProfile?
  privateSpace          PrivateSpace?
  checkIns              CheckIn[]
  goals                 Goal[]
  xpTransactions        XPTransaction[]
  schedule              MemberSchedule?
  voiceSessions         VoiceSession[]
  seasonSnapshots       SeasonSnapshot[]
  conversationMessages  ConversationMessage[]
  conversationSummary   ConversationSummary?
  notificationPreference NotificationPreference?
  memberAIBudget        MemberAIBudget?
  inspirations          Inspiration[]
  timerSessions         TimerSession[]
  reminders             Reminder[]
  reflections           Reflection[]
  refreshTokens         RefreshToken[]
}

/// Discord accounts linked to a member identity.
/// A member can have up to 5 linked accounts (ACCOUNT_LINK_CAP).
model DiscordAccount {
  discordId String   @id // Discord user snowflake ID
  memberId  String
  linkedAt  DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
}

/// Member profile -- stores both raw answers (encrypted) and structured tags.
/// Raw answers are encrypted at rest; structured tags are cleartext for queries.
model MemberProfile {
  id       String @id @default(cuid())
  memberId String @unique

  // Encrypted field (raw natural language answers as JSON)
  rawAnswers String // Encrypted JSON of { situation, interests, goals, learn, style }

  // Structured tags (NOT encrypted -- needed for queries, matching, leaderboards)
  interests     String[] // AI-extracted interest tags
  currentFocus  String?  // Primary focus area
  goals         String[] // AI-extracted goal tags
  learningAreas String[] // What they want to learn
  workStyle     String?  // How they prefer to work

  // Visibility control -- which fields other members can see
  publicFields String[] // e.g. ["interests", "currentFocus"]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

/// Private space preference per member.
/// Members choose DM or a dedicated private channel.
model PrivateSpace {
  id        String    @id @default(cuid())
  memberId  String    @unique
  type      SpaceType // DM or CHANNEL
  channelId String?   // Discord channel ID if type is CHANNEL

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

/// Private space type enum.
enum SpaceType {
  DM
  CHANNEL
}

/// Account linking codes -- temporary, TTL-based.
/// Generated by /link, consumed by /verify within 5 minutes.
model LinkCode {
  id          String   @id @default(cuid())
  code        String   @unique // 6-char alphanumeric uppercase
  requesterId String   // Discord ID of account requesting link
  expiresAt   DateTime // Created + 5 minutes
  used        Boolean  @default(false)

  @@index([code, expiresAt])
}

/// Interest tag roles managed by AI.
/// Tags are dynamically created/normalized -- synonyms merge, empty tags are cleaned up.
model InterestTag {
  id          String   @id @default(cuid())
  name        String   @unique // Normalized tag name
  roleId      String?  // Discord role ID (null if not yet created)
  memberCount Int      @default(0)
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime @default(now())
}

// ─── Phase 2: Daily Engagement Loop ───────────────────────────────────────────

/// Daily check-in record. Content is encrypted; categories are cleartext for queries.
model CheckIn {
  id           String   @id @default(cuid())
  memberId     String
  content      String   // Encrypted -- what the member did
  effortRating Int?     // Optional 1-5 effort self-rating
  categories   String[] // AI-extracted categories (cleartext for queries)
  xpAwarded    Int      @default(0)
  dayIndex     Int      // Which check-in this is today (1st, 2nd, etc.)
  createdAt    DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, createdAt])
}

/// Goal with measurable or free-text tracking.
/// Title stays cleartext for display; description is encrypted.
model Goal {
  id           String     @id @default(cuid())
  memberId     String
  title        String     // Goal title (cleartext for display)
  description  String?    // Encrypted -- detailed description
  type         GoalType   // MEASURABLE or FREETEXT
  targetValue  Int?       // For measurable goals (e.g., 5 cold emails)
  currentValue Int        @default(0) // Current progress
  unit         String?    // Unit of measurement (e.g., "emails", "pages")
  status       GoalStatus @default(ACTIVE)
  deadline     DateTime   // When the goal expires
  xpAwarded    Int        @default(0) // XP given on completion
  createdAt    DateTime   @default(now())
  completedAt  DateTime?
  extendedAt   DateTime?  // If member chose to extend

  // Hierarchy fields (Phase 11)
  parentId  String?        // FK to parent goal (null = standalone/top-level)
  timeframe GoalTimeframe? // Timeframe level (null = legacy standalone)
  depth     Int            @default(0) // 0 = top-level, 1-3 = nested depth

  parent   Goal?  @relation("GoalHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Goal[] @relation("GoalHierarchy")

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, status])
  @@index([deadline, status])
  @@index([parentId])
}

/// Goal type -- measurable with numeric tracking or free-text qualitative.
enum GoalType {
  MEASURABLE
  FREETEXT
}

/// Goal lifecycle status.
enum GoalStatus {
  ACTIVE
  COMPLETED
  MISSED
  EXTENDED
}

/// Goal timeframe level for hierarchical goals.
enum GoalTimeframe {
  YEARLY
  QUARTERLY
  MONTHLY
  WEEKLY
}

/// Immutable XP transaction log. Every XP award is recorded here.
/// Member.totalXp is the cached sum for fast reads.
model XPTransaction {
  id          String   @id @default(cuid())
  memberId    String
  amount      Int      // XP amount (always positive)
  source      XPSource // What triggered this award
  description String   // Human-readable description
  createdAt   DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, createdAt])
  @@index([source])
}

/// XP source enum -- what activity triggered the XP award.
enum XPSource {
  CHECKIN
  GOAL_COMPLETE
  STREAK_BONUS
  SETUP_BONUS
  VOICE_SESSION
  WIN_POST
  LESSON_POST
  RESOURCE_SHARE
  SESSION_HOST
  TIMER_SESSION
  REFLECTION
}

/// Per-member schedule preferences for briefs, reminders, and planning.
model MemberSchedule {
  id             String   @id @default(cuid())
  memberId       String   @unique
  timezone       String   @default("UTC") // IANA timezone string
  briefTime      String?  // HH:mm format for morning brief (null = no brief)
  briefTone      String   @default("coach") // coach, chill, data-first, etc.
  reminderTimes  String[] // Array of HH:mm strings for check-in reminders
  sundayPlanning Boolean  @default(true) // Whether to receive Sunday planning prompt

  accountabilityLevel String @default("medium") // light, medium, heavy
  nudgeTime           String?                   // HH:mm format for nudge time
  lastNudgeAt         DateTime?

  reflectionIntensity String @default("off") // off, light, medium, heavy

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

// ─── Phase 4: AI Assistant ────────────────────────────────────────────────────

/// Individual conversation message between a member and the AI assistant.
/// Content is encrypted at rest via the encryption extension.
model ConversationMessage {
  id        String   @id @default(cuid())
  memberId  String
  role      String   // 'user', 'assistant', 'system'
  content   String   // Encrypted at rest
  createdAt DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, createdAt])
}

/// Rolling conversation summary for a member. Replaces oldest messages
/// with a compressed summary to stay within the context token budget.
model ConversationSummary {
  id           String   @id @default(cuid())
  memberId     String   @unique
  summary      String   // Encrypted at rest
  messageCount Int      // How many messages are summarized into this summary
  updatedAt    DateTime @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

// ─── Phase 3: Competition and Social Proof ──────────────────────────────────

/// Voice co-working session. Tracked from join to leave in "Lock In" voice channels.
/// Duration excludes paused time (AFK channel, server-deafen).
model VoiceSession {
  id              String    @id @default(cuid())
  memberId        String
  channelId       String    // Discord voice channel ID
  startedAt       DateTime
  endedAt         DateTime?
  durationMinutes Int?
  seasonId        String?

  member  Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  season  Season? @relation(fields: [seasonId], references: [id])

  @@index([memberId, startedAt])
  @@index([seasonId])
}

/// Competitive season -- Valorant-style with archived past seasons.
/// Only one season is active at a time.
model Season {
  id        String    @id @default(cuid())
  number    Int       @unique
  startedAt DateTime
  endedAt   DateTime?
  active    Boolean   @default(true)

  voiceSessions VoiceSession[]
  snapshots     SeasonSnapshot[]
  timerSessions TimerSession[]

  @@index([active])
}

/// Season-end snapshot for a member in a specific dimension (xp, voice, streaks).
/// Preserves leaderboard positions after season ends for historical display.
model SeasonSnapshot {
  id        String @id @default(cuid())
  seasonId  String
  memberId  String
  dimension String // "xp", "voice", "streaks"
  position  Int
  value     Int

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([seasonId, memberId, dimension])
  @@index([seasonId])
}

// ─── Phase 5: Lock-In Sessions ──────────────────────────────────────────────

/// Member-initiated co-working session. Instant (/lockin) or scheduled (/schedule-session).
/// creatorMemberId is a plain string (no relation to Member) -- session records are communal,
/// not personal data, and persist even if the creator deletes their data.
model LockInSession {
  id              String            @id @default(cuid())
  creatorMemberId String
  voiceChannelId  String?           // Discord voice channel ID (null if scheduled but not started)
  textChannelId   String?           // Discord text channel for session announcements (for public sessions)
  title           String            // What the session is about
  visibility      SessionVisibility
  status          SessionStatus     @default(PENDING)
  scheduledFor    DateTime?         // Null for instant sessions
  startedAt       DateTime?
  endedAt         DateTime?
  durationMinutes Int?

  participants    SessionParticipant[]

  @@index([status])
  @@index([creatorMemberId])
  @@index([scheduledFor])
}

/// Participant in a lock-in session. Tracks join/leave for attendance summaries.
/// No Member relation -- session records are communal (not personal data).
model SessionParticipant {
  id        String    @id @default(cuid())
  sessionId String
  memberId  String
  role      String    @default("participant") // "creator" or "participant"
  joinedAt  DateTime  @default(now())
  leftAt    DateTime?

  session LockInSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, memberId])
  @@index([memberId])
}

/// Session visibility -- public (anyone can join) or private (invite-only).
enum SessionVisibility {
  PUBLIC
  PRIVATE
}

/// Session lifecycle status.
enum SessionStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

/// Key-value config store for persistent bot state.
/// Stores leaderboard message IDs, feature flags, and other runtime config.
model BotConfig {
  key   String @id
  value String
}

// ─── Phase 6: Polish and Launch Readiness ───────────────────────────────────

// ─── Phase 7: AI Infrastructure ──────────────────────────────────────────────

/// Per-request token usage tracking for cost visibility and budget enforcement.
/// Every AI call through the centralized client creates a row here.
model TokenUsage {
  id               String   @id @default(cuid())
  memberId         String   // 'system' for system-level calls (e.g., content filtering)
  feature          String   // 'chat', 'brief', 'nudge', 'filter', 'categories', 'tags', 'planning', 'summary', 'tagger'
  model            String   // OpenRouter model ID (e.g., 'x-ai/grok-4.1-fast')
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  estimatedCostUsd Float    // Computed from tokens * model pricing
  createdAt        DateTime @default(now())

  @@index([memberId, createdAt])
  @@index([createdAt])
  @@index([feature])
}

/// Per-member AI budget override. Null dailyTokenLimit means use default (500K).
model MemberAIBudget {
  id              String @id @default(cuid())
  memberId        String @unique
  dailyTokenLimit Int    // Override for this member

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

// ─── Phase 6: Polish and Launch Readiness ───────────────────────────────────

/// Per-member notification routing preferences.
/// Members with multiple linked accounts can choose which account
/// receives each notification type. Null = fall back to primary (default).
model NotificationPreference {
  id                    String  @id @default(cuid())
  memberId              String  @unique
  briefAccountId        String? // Discord account ID for morning briefs
  nudgeAccountId        String? // Discord account ID for accountability nudges
  sessionAlertAccountId String? // Discord account ID for session invites
  levelUpAccountId      String? // Discord account ID for level-up alerts
  reminderAccountId     String? // Discord account ID for reminders

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

/// Content feed source (RSS, YouTube, Reddit) for auto-feed curation.
model FeedSource {
  id        String   @id @default(cuid())
  name      String
  type      FeedType
  url       String
  active    Boolean  @default(true)
  channelId String?  // Discord channel ID for posting
  createdAt DateTime @default(now())

  posts FeedPost[]
}

/// Individual post from a feed source, tracked for deduplication and voting.
model FeedPost {
  id             String   @id @default(cuid())
  sourceId       String
  externalId     String   // External ID from the source (RSS GUID, YouTube video ID, etc.)
  title          String
  link           String
  category       String?
  relevanceScore Int?
  upvotes        Int      @default(0)
  downvotes      Int      @default(0)
  messageId      String?  // Discord message ID for the posted embed
  postedAt       DateTime @default(now())

  source FeedSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, externalId])
  @@index([postedAt])
}

/// Feed source type enum.
enum FeedType {
  RSS
  YOUTUBE
  REDDIT
}

// ─── Phase 8: Inspiration System ──────────────────────────────────────────────

/// A person who inspires a member. Each member can have up to 3 inspirations.
/// Used by Jarvis to personalize AI interactions with motivational references.
model Inspiration {
  id        String   @id @default(cuid())
  memberId  String
  name      String   // Name of the person they admire (e.g., "Steve Jobs", "Kobe Bryant")
  context   String?  // Optional -- why they admire this person
  createdAt DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, name])
  @@index([memberId])
}

// ─── Phase 9: Productivity Timer ─────────────────────────────────────────────

/// Personal productivity timer session. Supports Pomodoro (structured work/break cycles)
/// and Proportional (work freely, get proportional break) modes.
/// Active state is held in-memory; DB record is created on start for restart recovery.
model TimerSession {
  id                String       @id @default(cuid())
  memberId          String
  mode              TimerMode
  status            TimerStatus  @default(ACTIVE)
  focus             String?      // What they were working on (free text)
  timerState        String?      // Persisted timer state for recovery (working/on_break/paused)
  prePauseState     String?      // Pre-pause state for recovery (working/on_break when paused)
  remainingMs       Int?         // Remaining interval ms when paused (for recovery)
  goalId            String?      // Linked goal ID if any
  workDuration      Int          // Configured work interval in minutes
  breakDuration     Int          // Configured break interval in minutes
  breakRatio        Float        @default(5.0) // For proportional mode
  totalWorkedMs     Int          @default(0)   // Total work time in milliseconds
  totalBreakMs      Int          @default(0)   // Total break time in milliseconds
  pomodoroCount     Int          @default(0)   // Completed work intervals
  xpAwarded         Int          @default(0)
  startedAt         DateTime     @default(now())
  endedAt           DateTime?
  lastStateChangeAt DateTime     @default(now()) // For restart recovery elapsed time calculation
  dmMessageId       String?      // Discord message ID of the live timer DM
  dmChannelId       String?      // Discord DM channel ID
  seasonId          String?
  targetSessions    Int?         // Number of pomodoro sessions to chain (1-12, null=unlimited)
  longBreakDuration Int?         // Long break duration in minutes
  longBreakInterval Int?         // Every N sessions, use long break instead of normal break
  source            String       @default("BOT")   // "BOT" or "DESKTOP" -- where session originated
  botNotified       Boolean      @default(false)    // Whether the bot has been notified of this session

  member  Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  season  Season? @relation(fields: [seasonId], references: [id])

  @@index([memberId, status])
  @@index([status])
}

// ─── Phase 10: Smart Reminders ─────────────────────────────────────────────

/// Scheduled reminder with urgency tiers, recurrence support, and restart recovery.
/// Active state uses setTimeout in-memory; DB record persists across restarts.
model Reminder {
  id             String          @id @default(cuid())
  memberId       String
  content        String          // What to remind about (plain text)
  urgency        ReminderUrgency @default(LOW)
  fireAt         DateTime?       // Next fire time (null for cancelled/fired)
  cronExpression String?         // For recurring reminders (e.g., "30 9 * * 1" = every Monday 9:30)
  status         ReminderStatus  @default(PENDING)
  skipUntil      DateTime?       // Skip next occurrence before this time
  repeatCount    Int             @default(0) // How many times high urgency has repeated
  acknowledged   Boolean         @default(false) // Whether member acknowledged high urgency
  dmMessageId    String?         // Discord message ID for button tracking
  createdAt      DateTime        @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, status])
  @@index([status, fireAt])
}

/// Reminder urgency tier -- determines delivery style.
enum ReminderUrgency {
  LOW
  HIGH
}

/// Reminder lifecycle status.
enum ReminderStatus {
  PENDING
  ACTIVE
  FIRED
  CANCELLED
}

/// Timer mode -- Pomodoro (structured cycles) or Proportional (free-form with ratio-based breaks).
enum TimerMode {
  POMODORO
  PROPORTIONAL
}

/// Timer session lifecycle status.
enum TimerStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

// ─── Phase 12: Self-Evaluation and Reflection ──────────────────────────────

/// Self-evaluation reflection record. AI-generated questions with member responses.
/// Content is encrypted at rest; insights are AI-extracted summaries.
model Reflection {
  id        String         @id @default(cuid())
  memberId  String
  type      ReflectionType // DAILY, WEEKLY, MONTHLY
  question  String         // The AI-generated question asked
  response  String         // Member's natural language response (encrypted)
  insights  String?        // AI-extracted key insight (1-2 sentences)
  createdAt DateTime       @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, createdAt])
  @@index([memberId, type])
}

/// Reflection type -- frequency of self-evaluation prompts.
enum ReflectionType {
  DAILY
  WEEKLY
  MONTHLY
}

// ─── Phase 15: REST API Authentication ──────────────────────────────────────

/// Refresh token for JWT token rotation. Each token is single-use;
/// on refresh the old token is deleted and a new one is created.
model RefreshToken {
  id        String   @id @default(cuid())
  memberId  String
  token     String   @unique // Random 64-byte hex string
  expiresAt DateTime
  createdAt DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([token, expiresAt])
}
